{
  "name": "@arts/fluid-design-system",
  "author": "Artem Semkin",
  "version": "2.4.0",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "description": "",
  "private": true,
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@artemsemkin/elementor-types": "^1.0.10",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/jquery": "^4.0.0",
    "@types/node": "^25.5.2",
    "@types/select2": "^4.0.63",
    "@types/underscore": "^1.13.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@wordpress/env": "^11.3.0",
    "archiver": "^7.0.1",
    "browser-sync": "^3.0.4",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "debounce": "^3.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "fs-extra": "^11.3.4",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^20.0.0",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "typescript": "^6.0.2",
    "vitepress": "^2.0.0-alpha.17",
    "vitepress-plugin-lightbox": "^1.0.3",
    "vitepress-sidebar": "^1.33.1",
    "vitest": "^4.1.2",
    "wp-pot": "^1.10.2"
  },
  "scripts": {
    "dev": "node __build__/index.js dev",
    "build:js": "node __build__/index.js build",
    "build": "composer install --quiet && composer prefix-namespaces && npm run build:js",
    "version": "npm run build && node scripts/sync-changelog.js && git add src/wordpress-plugin/ CHANGELOG.md",
    "deps:check": "npx npm-check-updates",
    "deps:update": "npx npm-check-updates -u && npm install",
    "format": "prettier --write 'src/ts/**/*.{ts,js,jsx,json,css}' 'docs/**/*.md' '*.md'",
    "format:check": "prettier --check 'src/ts/**/*.{ts,js,jsx,json,css}' 'docs/**/*.md' '*.md'",
    "test": "vitest run",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "wp-env": "wp-env",
    "wp-env:start": "npm run build && wp-env start",
    "wp-env:stop": "wp-env stop",
    "wp-env:clean": "wp-env clean",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "lint-staged": {
    "src/ts/**/*.{ts,js,json,css}": "prettier --write",
    "docs/**/*.md": "prettier --write",
    "*.md": "prettier --write"
  },
  "dependencies": {}
}
